<style>
/* Estilos base calcados de la captura /
body {
background-color: #1c100b; / Marrón oscuro exacto de la imagen */
color: #ffffff;
font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
display: flex;
align-items: center;
justify-content: center;
min-height: 100vh;
margin: 0;
overflow: hidden;
position: relative;
}

/* Contenedor del fondo con la silueta del burro /
.canvas {
display: grid;
grid-template-columns: repeat(12, 25px);
grid-template-rows: repeat(10, 25px);
gap: 2px;
position: absolute;
z-index: 1;
/ Centrado absoluto detrás de la tarjeta */
top: 45%;
left: 50%;
transform: translate(-50%, -50%);
}

/* Cada ícono de burrito en el fondo /
.pixel {
width: 25px;
height: 25px;
display: flex;
align-items: center;
justify-content: center;
font-size: 20px;
opacity: 0; / Ocultos al inicio */
transform: scale(0.3);
transition: opacity 0.4s ease, transform 0.4s ease;
}

/* Activación progresiva de los burritos /
.active {
opacity: 0.35; / Efecto translúcido de fondo como la captura */
transform: scale(1);
}

/* Tarjeta flotante central translúcida /
.tarjeta-mensaje {
background-color: rgba(25, 15, 10, 0.65); / Capa oscura translúcida /
